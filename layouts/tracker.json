{
    "tracker_horizontal": {
        "type": "container",
        "background": "#00000000",
        "content": {
            "type": "dock",
            "dropshadow": true,
            "content": [
                {
                    "type": "dock",
                    "dock": "bottom",
                    "content": [
                        {
                            "type": "group",
                            "header": "Items",
                            "dock": "left",
                            "margin": "0,0,3,0",
                            "content": {
                                "type": "layout",
                                "h_alignment": "center",
                                "v_alignment": "center",
                                "key": "shared_item_grid_horizontal"
                            }
                        }
                    ]
                }
            ]
        }
    },
	"settings_popup": {
		"type": "array",
		"orientation": "horizontal",
		"h_alignment": "left",
		"content": [
			{
				"type": "group",
				"header": "Settings",
				"dock": "bottom",
				"content": {
					"type": "layout",
					"key": "settings_grid"
				}
			}
		]
	}
}